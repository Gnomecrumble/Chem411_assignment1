import uasyncio as asyncio
from machine import Pin, I2C, ADC
import time
import aioble
from bt_esp32_api import BLE
import i2c_lcd

# ------------- BLE SETUP -------------

SERVICE_UUID = "19b10000-e8f2-537e-4f6c-d104768a1214"
SENSOR_TX_UUID = "19b10001-e8f2-537e-4f6c-d104768a1214"

# ------------- HARDWARE SETUP -------------

# LCD
screen = I2C(0, scl=Pin(22), sda=Pin(21))
lcd = i2c_lcd.I2cLcd(screen, 0x27, 2, 16)

# Light sensor
lightsensor = ADC(Pin(34))
lightsensor.atten(ADC.ATTN_11DB)

# Rotary encoder pins
Sw1 = Pin(26, Pin.IN, Pin.PULL_UP)
Sw2 = Pin(25, Pin.IN, Pin.PULL_UP)

# Encoder push button
button = Pin(23, Pin.IN, Pin.PULL_UP)
button_last = button.value()
button_last_change = time.ticks_ms()

# LEDs
led_b = Pin(13, Pin.OUT)   # above MAX / below MIN visual
led_a = Pin(14, Pin.OUT)   # indicates "sending enabled"

# Sending enable switch
send_switch = Pin(27, Pin.IN, Pin.PULL_UP)  # external toggle

# Thresholds
MIN_val = 0       # dark limit
MAX_val = 4095    # bright limit

# Encoder state
mode = "MIN"
last_b = Sw2.value()

# Shared brightness for BLE
current_brightness = 0


# ------------- FUNCTIONS -------------

def read_brightness():
    raw = lightsensor.read()
    return 4095 - raw          # 0 = darkest, 4095 = brightest


def update_mode_and_lcd(last_b, mode):
    b = Sw2.value()
    if last_b == 1 and b == 0:
        a = Sw1.value()
        if a == 1:
            mode = "MIN"        # one direction
        else:
            mode = "MAX"        # other direction

    lcd.move_to(0, 1)
    if mode == "MIN":
        lcd.putstr("[MIN]  MAX ")
    else:
        lcd.putstr(" MIN  [MAX] ")

    return b, mode


def draw_bar(MIN_val, MAX_val):
    global current_brightness

    brightness = read_brightness()
    current_brightness = brightness

    # LED on if outside range
    led_b.value(1 if brightness < MIN_val or brightness > MAX_val else 0)

    # clamp brightness
    if brightness < MIN_val:
        brightness = MIN_val
    elif brightness > MAX_val:
        brightness = MAX_val

    span = MAX_val - MIN_val or 1

    position = (brightness - MIN_val) / span
    bars = int(position * 16)

    bar_str = "-" * bars + " " * (16 - bars)
    lcd.move_to(0, 0)
    lcd.putstr(bar_str)


def change_level(button_last, button_last_change, mode, MIN_val, MAX_val):
    now = time.ticks_ms()
    val = button.value()
    if val != button_last and time.ticks_diff(now, button_last_change) > 50:
        button_last_change = now
        button_last = val
        if val == 0:  # pressed
            brightness = read_brightness()
            if mode == "MIN":
                MIN_val = brightness
            else:
                MAX_val = brightness

    return button_last, button_last_change, MIN_val, MAX_val


# ------------- ASYNC TASKS -------------

async def ui_task():
    global last_b, mode, button_last, button_last_change, MIN_val, MAX_val
    while True:
        last_b, mode = update_mode_and_lcd(last_b, mode)
        button_last, button_last_change, MIN_val, MAX_val = change_level(
            button_last, button_last_change, mode, MIN_val, MAX_val
        )
        draw_bar(MIN_val, MAX_val)
        await asyncio.sleep_ms(5)


async def sensor_task(ble, period_ms=3000):
    global MIN_val, MAX_val, current_brightness

    while True:
        # Check switch
        sending_enabled = send_switch.value() == 1  # active high
        led_a.value(1 if sending_enabled else 0)

        if sending_enabled:
            # Construct payload from live values
            max_val = MAX_val
            min_val = MIN_val
            reading_val = current_brightness

            msg = f"{max_val},{min_val},{reading_val}".encode()
            ble.send(msg)
            print("BLE:", max_val, min_val, reading_val)

        await asyncio.sleep_ms(period_ms)


async def main():
    # Start BLE
    ble = BLE(
        name='OLLIEESP32',
        service_uuid=SERVICE_UUID,
        tx_char_uuid=SENSOR_TX_UUID,
        adv_interval_us=250_000
    )
    await ble.start_adv()
    print('BLE started, advertising...')

    # Spawn tasks
    ui = asyncio.create_task(ui_task())
    sensor = asyncio.create_task(sensor_task(ble, period_ms=3000))

    try:
        # Run forever
        await asyncio.gather(ui, sensor)
    finally:
        await ble.stop()
        print('stopped')


asyncio.run(main())
